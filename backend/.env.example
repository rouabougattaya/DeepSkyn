# ===================================
# DeepSkyn Environment Configuration
# ===================================
# Copy to .env.local and fill in values
# NEVER commit secrets to git!

# ----- CORE APPLICATION -----
NODE_ENV=development
PORT=3001
APP_NAME=DeepSkyn
APP_VERSION=1.0.0

# ----- DATABASE -----
# Option 1: Using DATABASE_URL (Recommended)
# DATABASE_URL=postgresql://user:pass@localhost:5432/deepskyn_db

# Option 2: Individual variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepskyn_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_POOL_SIZE=10
DB_MAX_QUERY_TIME=5000

# ----- SECURITY: JWT (REQUIRED) -----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars_1234567890123456
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_min_32_chars_1234567890
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# ----- SECURITY: COOKIES -----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your_super_secure_cookie_secret_min_32_chars_1234567890

# ----- STRIPE PAYMENT -----
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ----- CORS & FRONTEND -----
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ----- GOOGLE OAUTH (Optional) -----
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ----- AI SERVICES -----
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_GENAI_API_KEY=your_google_genai_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# ----- EMAIL -----
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@deepskyn.com

# SMTP Alternative
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# ----- SECURITY: reCAPTCHA -----
RECAPTCHA_SITE_KEY=6Le2AXUsAAAAAH_UQWtmFFqFsJ33EH8yZEfhzqZS
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ----- RATE LIMITING -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- LOGGING -----
LOG_LEVEL=debug

# ----- MONITORING (Optional) -----
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
