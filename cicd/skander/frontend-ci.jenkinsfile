pipeline {
    agent any
    environment {
        MEMBER_NAME = "Skander"
        PROJECT_KEY = "DeepSkyn:{MEMBER_NAME}:Frontend"
    }
    stages {
        stage('Install') { steps { dir('frontend') { sh 'npm install' } } }
        stage('Tests') { steps { dir('frontend') { sh 'npm run test -- --grep="Session|Filters|Comparison|Pricing"' } } }
    }
    post { success { build job: "${MEMBER_NAME}/frontend-cd", wait: false } }
}