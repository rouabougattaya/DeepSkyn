<div class="form-body">
    {{ form_start(form, {'attr': {'class': 'form-horizontal'}}) }}

    <div class="col-md-6">
        {% set skip_next = false %}
        {% for field in form %}
            {% if skip_next %}
                {% set skip_next = false %}
            {% else %}
                {% if field.vars.name == '_token' %}
                    {# Ne rien afficher pour le token #}
                {% elseif field.vars.name == 'codeReferenceGroupe' %}
                    <div class="form-group mb-3">
                        {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(field, {'attr': {'class': 'form-control', 'autocomplete': 'off'}}) }}
                        {{ form_errors(field) }}
                    </div>
                {% elseif field.vars.name == 'prix' %}
                    <div class="form-group mb-3 d-flex align-items-start">
                        <div style="flex: 1; margin-right: 15px;">
                            {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(field) }}
                        </div>
                        <div style="flex: 1;">
                            {{ form_label(form.currency, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.currency, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.currency) }}
                        </div>
                    </div>
                    {% set skip_next = true %}
                {% elseif field.vars.name == 'currency' %}
                    {# Déjà affiché avec prix #}
                {% elseif field.vars.name == 'restrictCMD' %}
                    {# Champ affiché plus bas #}
                {% elseif field.vars.name == 'typeArticle' %}
                    <div id="type-article-wrapper" class="form-group mb-3" style="display: none;">
                        {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(field) }}
                    </div>
                {% else %}
                    <div class="form-group mb-3">
                        {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(field) }}
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}
    </div>

    <div class="clearfix"></div>
    <hr>

    <div class="col-md-6">
        <div class="form-group mb-3">
            {{ form_label(form.restrictCMD, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.restrictCMD, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.restrictCMD) }}
        </div>
    </div>

    <div class="col-md-12 form-group">
        <button type="submit" class="btn btn-success">{{ button_label|default('Save') }}</button>
    </div>

    {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const codeRefField = document.getElementById('article_codeReferenceGroupe');
    const typeArticleWrapper = document.getElementById('type-article-wrapper');
    const typeArticleField = document.getElementById('article_typeArticle');

    if (!codeRefField || !typeArticleWrapper || !typeArticleField) return;

    typeArticleWrapper.style.display = 'none';
    typeArticleField.required = false;

    let debounceTimeout;

    const checkGroupExists = async (code) => {
        try {
            const response = await fetch(`/article/check-groupe-exists?code=${encodeURIComponent(code)}`);
            if (!response.ok) throw new Error('Erreur API');
            const data = await response.json();
            return data.exists;
        } catch (error) {
            console.error('Erreur fetch:', error);
            return true;  // Supposons groupe existe en cas d'erreur pour ne pas afficher typeArticle
        }
    };

    const updateTypeFieldState = async () => {
        const code = codeRefField.value.trim();
        if (!code) {
            typeArticleWrapper.style.display = 'none';
            typeArticleField.required = false;
            return;
        }

        const groupExists = await checkGroupExists(code);

        if (groupExists) {
            typeArticleWrapper.style.display = 'none';
            typeArticleField.required = false;
            typeArticleField.value = '';
        } else {
            typeArticleWrapper.style.display = 'block';
            typeArticleField.required = true;
        }
    };

    codeRefField.addEventListener('input', () => {
        clearTimeout(debounceTimeout);
        debounceTimeout = setTimeout(updateTypeFieldState, 400);
    });

    if (codeRefField.value.trim()) {
        updateTypeFieldState();
    }
});
</script>
