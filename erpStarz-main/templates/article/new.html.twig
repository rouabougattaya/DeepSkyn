{% extends 'base.html.twig' %}

{% block title %}New Article{% endblock %}

{% block body %}
<div class="forms">
    <h2 class="title1">Article Information</h2>
    <div class="form-grids row widget-shadow">
        <div class="form-title">
            <div class="pull-right">
                <a href="{{ path('app_article_index') }}" class="btn btn-primary">
                    <i class="fa fa-arrow-left"></i> Back to list
                </a>
            </div>
            <ol class="breadcrumb m-b-0">
                <li><a href="{{ path('dashboard') }}">Home</a></li>
                <li class="active">New Article</li>
            </ol>
        </div>
        <div class="form-body">
            {{ form_start(form, {'attr': {'class': 'form-horizontal', 'novalidate': 'novalidate'}}) }}

            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.codeReferenceGroupe, 'Group Reference Code', {'label_attr': {'class': 'control-label'}}) }}
                    {{ form_widget(form.codeReferenceGroupe, {
                        'attr': {
                            'class': 'form-control',
                            'autocomplete': 'off',
                            'data-check-url': path('app_article_check_groupe_exists'),
                            'placeholder': 'Enter reference code'
                        }
                    }) }}
                    {{ form_errors(form.codeReferenceGroupe) }}
                    <small class="text-muted">Enter an existing code or create a new group</small>
                </div>

                <div id="type-article-wrapper" class="form-group" style="display: none;">
                    {{ form_label(form.typeArticle, 'Article Type', {'label_attr': {'class': 'control-label'}}) }}
                    {{ form_widget(form.typeArticle, {
                        'attr': {
                            'class': 'form-control select2',
                            'data-placeholder': 'Select a type'
                        }
                    }) }}
                    {{ form_errors(form.typeArticle) }}
                </div>

                {% for child in form|filter(child => child.vars.name not in ['codeReferenceGroupe', 'typeArticle', '_token']) %}
                    <div class="form-group">
                        {{ form_row(child, {
                            'attr': {'class': 'form-control'},
                            'label_attr': {'class': 'control-label'}
                        }) }}
                    </div>
                {% endfor %}
            </div>

            <div class="col-md-12 form-group text-right">
                <button type="submit" class="btn btn-success">
                    <i class=></i> {{ button_label|default('Save') }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const codeRefInput = document.querySelector('#{{ form.codeReferenceGroupe.vars.id }}');
    const typeArticleWrapper = document.querySelector('#type-article-wrapper');
    const typeArticleSelect = document.querySelector('#{{ form.typeArticle.vars.id }}');

    if (!codeRefInput || !typeArticleWrapper || !typeArticleSelect) {
        console.error('Form elements not found');
        return;
    }

    let debounceTimer;
    const DEBOUNCE_DELAY = 500;

    const toggleTypeField = (show) => {
        typeArticleWrapper.style.display = show ? 'block' : 'none';
        typeArticleSelect.required = show;
        if (show) {
            typeArticleSelect.setAttribute('required', 'required');
        } else {
            typeArticleSelect.removeAttribute('required');
        }
    };

    const checkGroupExists = async (code) => {
        if (!code.trim()) {
            toggleTypeField(false);
            return;
        }

        try {
            const response = await fetch(`${codeRefInput.dataset.checkUrl}?code=${encodeURIComponent(code)}`);
            if (!response.ok) throw new Error('Server error');
            const data = await response.json();
            toggleTypeField(!data.exists);
            
            if (data.exists && data.type) {
                // Pre-select type if group exists
                typeArticleSelect.value = data.type;
            }
        } catch (error) {
            console.error('Error:', error);
            toggleTypeField(false);
        }
    };

    codeRefInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            checkGroupExists(codeRefInput.value);
        }, DEBOUNCE_DELAY);
    });

    codeRefInput.addEventListener('blur', () => {
        clearTimeout(debounceTimer);
        checkGroupExists(codeRefInput.value);
    });

    // Initial check if value exists (edit mode)
    if (codeRefInput.value) {
        checkGroupExists(codeRefInput.value);
    }
});
</script>
{% endblock %}